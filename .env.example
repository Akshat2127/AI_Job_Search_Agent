DATABASE_URL=sqlite:///./jobagent.db
APP_ENV=local
APP_NAME=JobAgent AI
APP_VERSION=1.0.0
LOG_LEVEL=INFO
LOG_FORMAT=console
CORS_ORIGINS=["http://localhost:3000"]
AUTO_CREATE_TABLES=false
AUTH_MODE=development
DEVELOPMENT_USER_EMAIL=local@jobagent.invalid
SESSION_TTL_HOURS=12
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_NAME=jobagent_session
CSRF_COOKIE_NAME=jobagent_csrf
CSRF_HEADER_NAME=X-CSRF-Token
UPLOAD_ROOT=./storage/uploads
MAX_RESUME_BYTES=10485760
LLM_PROVIDER=mock
OPENAI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
